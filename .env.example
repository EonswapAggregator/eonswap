# ========================================
# ENVIRONMENT CONFIGURATION
# ========================================
# Copy this file to:
#   - .env.production (for production builds)
#   - .env.development (for local development)
#
# Network Behavior:
#   - PRODUCTION (npm run build): Base mainnet only
#   - DEVELOPMENT (npm run dev): Base + Sepolia testnet
#
# Pre-configured templates available:
#   - .env.production (Base only, optimized)
#   - .env.development (Base + Sepolia for testing)

# Frontend (client-visible; do not put private secrets here)
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
VITE_ALCHEMY_API_KEY=your_alchemy_api_key

# Eon AMM HTTP router
# No trailing /v1 — the app calls `${VITE_EON_AMM_API_BASE_URL}/v1/quote` and `/v1/route/build`.
# On-chain addresses: `src/lib/eonBaseMainnet.ts` (sync with `eon-protocol/deployments/base-mainnet.json`).
VITE_EON_AMM_API_BASE_URL=https://api.example.com
VITE_EON_AMM_API_KEY=

# Frontend display fee in basis points (25 = 0.25%)
VITE_SWAP_FEE_BPS=25

# Optional per-contract token logos: VITE_TOKEN_LOGO_<lowercase_0x_address> (42-char address key; native = 0xeeee…eeee).
# Full https URL or site path. Allowed: webp, png, gif, svg, avif, ico — not jpg/jpeg. See src/lib/tokenLogos.ts.
# VITE_TOKEN_LOGO_0x295685df8e07a6d529a849ae7688c524494fd010=https://cdn.example/estf.webp
VITE_ETHERSCAN_API_KEY=your_etherscan_api_key
VITE_SITE_DOMAIN=example.com
# Full URL (https://...) recommended; bare hostname gets https:// prepended in the app.
VITE_MONITOR_RELAY_URL=

# ========================================
# SECURITY: EXACT APPROVAL ONLY
# ========================================
# ✅ AUDIT FIX (H-1): Always use 'exact' approval (never 'max')
# This prevents unlimited token approvals (security vulnerability)
# ERC20 approval mode: exact (safer, default) or max (fewer approvals).
VITE_SWAP_APPROVAL_MODE=exact
# Status health panel source: 1 = relay only (recommended), 0 = allow direct public API fallback.
VITE_STATUS_HEALTH_RELAY_ONLY=1
# Wallet on-chain tx history source: 1 = relay only (recommended), 0 = allow direct client fallback.
VITE_WALLET_TX_RELAY_ONLY=1
VITE_HEALTH_WARN_COINGECKO_MS=2500
VITE_HEALTH_WARN_ETHERSCAN_MS=3000
# Optional Swap Max reserve tuning (wei). Chain-specific key wins over global.
# Base mainnet (8453) example: 0.00015 ETH = 150000000000000 wei
VITE_SWAP_NATIVE_RESERVE_WEI_8453=150000000000000
# Sepolia testnet (11155111) example: 0.0015 ETH = 1500000000000000 wei
# (Only used in development mode; production builds exclude Sepolia)
# VITE_SWAP_NATIVE_RESERVE_WEI_11155111=1500000000000000
# Global fallback for all chains:
# VITE_SWAP_NATIVE_RESERVE_WEI=
# Gas buffer for reserve estimate in bps (default 11000 = 110%).
VITE_SWAP_GAS_BUFFER_BPS=11000

# ESTF price chip: pool ESTF/WETH on Base is primary; use hardcoded while pool not ready.
VITE_ESTF_HARDCODED_USD=0.002
# Optional extra fallback if hardcoded is omitted/zero.
VITE_ESTF_COINGECKO_ID=
VITE_ESTF_SYMBOL=ESTF

# Optional backend relay (Etherscan health on relay: use one of these — not only VITE_* on Netlify)
RELAY_PORT=8787
ETHERSCAN_API_KEY=your_etherscan_api_key
RELAY_ETHERSCAN_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RELAY_ALERT_WEBHOOK_URL=
RELAY_ALERT_COOLDOWN_MS=180000
RELAY_WARN_EONSWAP_MS=2500
RELAY_WARN_COINGECKO_MS=2500
RELAY_WARN_ETHERSCAN_MS=3000
RELAY_TELEGRAM_BOT_TOKEN=
RELAY_TELEGRAM_CHAT_ID=
# Optional public image URL shown above Telegram caption (sendPhoto mode).
RELAY_TELEGRAM_BANNER_URL=
# Optional local image path fallback for sendPhoto when URL is rejected.
RELAY_TELEGRAM_BANNER_LOCAL_PATH=
# One origin, or comma-separated (e.g. https://eonswap.us,http://localhost:5173).
RELAY_ALLOWED_ORIGIN=https://eonswap.us
RELAY_EVENTS_RATE_LIMIT_PER_MIN=60
RELAY_EXPLORER_RATE_LIMIT_PER_MIN=20
RELAY_EXPLORER_ACCESS_TOKEN=
RELAY_EVENTS_MAX_BODY_BYTES=262144
RELAY_ADMIN_SECRET=generate_a_long_random_secret
RELAY_ACTIVITY_LOG_PATH=

# The Graph gateway proxy (server-side only; do not expose the API key as VITE_*).
# Frontend keeps calling your relay; relay calls The Graph with short cache TTL.
THE_GRAPH_API_KEY=
THE_GRAPH_SUBGRAPH_ID=FoKBv95x7Z8uMuBZsBTkHKyHFGE9DTVVicwHp3U3eT5s
THE_GRAPH_SUBGRAPH_URL=https://gateway.thegraph.com/api/subgraphs/id/FoKBv95x7Z8uMuBZsBTkHKyHFGE9DTVVicwHp3U3eT5s
THE_GRAPH_CACHE_MS=30000
