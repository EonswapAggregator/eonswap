{
  "name": "eonswap",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/prebuild-token-logos.mjs",
    "build": "node scripts/generate-sitemap.mjs && tsc -b && vite build && npm run docs:build && node scripts/merge-docs-into-dist.mjs",
    "preview": "vite preview",
    "docs:dev": "vitepress dev documentation/docs --host 0.0.0.0 --port 4174",
    "docs:build": "vitepress build documentation/docs",
    "docs:preview": "vitepress preview documentation/docs --host 0.0.0.0 --port 4174",
    "lint": "eslint .",
    "validate:token-logos": "tsx scripts/validate-token-logos.ts",
    "fetch:token-logos": "tsx scripts/fetch-token-logos.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "test:api": "tsx tests/api/api-contract.test.ts",
    "monitor:relay": "node --env-file=.env.local ./relay/server.mjs",
    "monitor:indexer": "set INDEXER_ENABLED=1&& node --env-file=.env.local ./relay/server.mjs"
  },
  "dependencies": {
    "@rainbow-me/rainbowkit": "^2.2.4",
    "@tanstack/react-query": "^5.66.0",
    "framer-motion": "^12.4.7",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.1.1",
    "sonner": "^2.0.7",
    "viem": "^2.23.2",
    "wagmi": "^2.14.11",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@netlify/functions": "^5.2.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.19.17",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vercel/node": "^5.7.10",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.19.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "postcss": "^8.5.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.22.0",
    "vite": "^6.1.0",
    "vitepress": "^1.6.4"
  },
  "overrides": {
    "axios": "1.16.0",
    "@coinbase/cdp-sdk": {
      "axios": "1.16.0"
    },
    "@vueuse/integrations": {
      "axios": "1.16.0"
    },
    "axios-retry": {
      "axios": "1.16.0"
    },
    "@vercel/static-config": {
      "ajv": "8.20.0"
    },
    "esbuild": "0.25.12",
    "minimatch": "10.2.5",
    "path-to-regexp": "6.3.0",
    "smol-toml": "1.6.1",
    "undici": "6.25.0",
    "vitepress": {
      "vite": "6.4.2"
    }
  }
}
